# Copy to secrets.yaml, fill in real values, and apply with:
# kubectl apply -f secrets.yaml
# DO NOT commit secrets.yaml — it is in .gitignore
apiVersion: v1
kind: Secret
metadata:
  name: storedge-secrets
  namespace: storedge
type: Opaque
stringData:
  DATABASE_URL: "postgresql://storedge:PASSWORD@postgres-host:5432/storedge"
  JWT_SECRET: "change-me-to-a-32-char-random-string"
  NERL_API_URL: "https://api.nerl.in/v1"
  NERL_API_KEY: "your-nerl-api-key"
  WHATSAPP_TOKEN: "your-meta-whatsapp-token"
  VITE_MAPBOX_TOKEN: "your-mapbox-public-token"
  AWS_IOT_ENDPOINT: "your-iot-core-endpoint.iot.ap-south-1.amazonaws.com"
  AWS_IOT_CERT_PEM: "-----BEGIN CERTIFICATE-----..."
  AWS_IOT_KEY_PEM: "-----BEGIN RSA PRIVATE KEY-----..."

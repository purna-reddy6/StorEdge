# =============================================
# StorEdge — Environment Variables Template
# Copy to .env and fill in real values
# =============================================

# --- Database ---
DATABASE_URL=postgres://storedge:storedge_dev@localhost:5432/storedge?sslmode=disable
POSTGRES_DB=storedge
POSTGRES_USER=storedge
POSTGRES_PASSWORD=storedge_dev

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=storedge-consumers

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_WAREHOUSES=warehouses

# --- Auth ---
JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# --- Mapbox (Web Map) ---
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX01BUEJPWCtUT0tFTiJ9.PLACEHOLDER

# --- External APIs (stubbed in dev, required in prod) ---
# WDRA NERL Repository API
NERL_API_URL=https://nerl.co.in/api/v1
NERL_API_KEY=

# WDRA CCRL Repository API
CCRL_API_URL=https://ccrl.co.in/api/v1
CCRL_API_KEY=

# WhatsApp Business API (Meta)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# Stripe (payment processing)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# --- IoT / AWS ---
AWS_IOT_ENDPOINT=placeholder.iot.ap-south-1.amazonaws.com
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Service Ports ---
SEARCH_MATCH_GRPC_PORT=50051
SEARCH_MATCH_HTTP_PORT=8080
INVENTORY_WMS_PORT=8081
FINANCING_ENWRS_PORT=8082
IOT_GATEWAY_PORT=8083
AI_ENGINE_PORT=8084

# --- Business Config ---
PLATFORM_COMMISSION_RATE=0.15
LOGISTICS_DISPATCH_FEE=0.08
ENWRS_ORIGINATION_FEE=0.015
INSURANCE_COMMISSION_RATE=0.20
TARGET_UTILIZATION_RATE=0.85

# --- Environment ---
APP_ENV=development
LOG_LEVEL=debug
